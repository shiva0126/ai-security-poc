# ── Qualys TotalAI MCP Server ─────────────────────────────────────────────────
QUALYS_BASE_URL=https://gateway.qg1.apps.qualys.com
QUALYS_USERNAME=your-qualys-username
QUALYS_PASSWORD=your-qualys-password
QUALYS_TIMEOUT_MS=30000
QUALYS_MOCK_MODE=1          # set to 0 with live credentials

# ── CrowdStrike AIDR ──────────────────────────────────────────────────────────
CS_AIDR_TOKEN=your-crowdstrike-aidr-token
CS_AIDR_BASE_URL=https://api.aidr.crowdstrike.com

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-demo-master-key

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_AUTH_TOKEN=demo-chroma-token

# ── MCP Server transport ──────────────────────────────────────────────────────
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8765
