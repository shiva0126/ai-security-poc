FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir fastapi==0.111.0 uvicorn==0.29.0 requests==2.31.0
COPY findings.py dashboard.py ./
RUN mkdir -p data
EXPOSE 9002
HEALTHCHECK --interval=15s --timeout=5s --retries=10 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:9002/api/summary')"
CMD ["uvicorn", "dashboard:app", "--host", "0.0.0.0", "--port", "9002"]
